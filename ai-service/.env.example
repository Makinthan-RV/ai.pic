# Copy to .env and adjust as needed.

# Where images and the SQLite face DB are stored (relative to ai-service/).
DATA_DIR=data

# Cosine-similarity cutoff for a selfie->photo match.
#   0.30  -> loose (more results, more false positives)
#   0.35  -> balanced default
#   0.45+ -> strict (fewer false positives, may miss some)
MATCH_THRESHOLD=0.35
