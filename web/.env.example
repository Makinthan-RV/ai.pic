# ---- Supabase (Auth + Postgres) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is server-only. NEVER expose it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Cloudflare R2 (S3-compatible) ----
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET=event-photos
# Public base URL for objects (r2.dev URL or your custom domain, no trailing slash)
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# ---- Python AI service (existing FastAPI) ----
AI_SERVICE_URL=http://127.0.0.1:8000

# ---- App ----
# Public base URL of THIS Next.js app, used to build QR links.
NEXT_PUBLIC_APP_URL=http://localhost:3000
